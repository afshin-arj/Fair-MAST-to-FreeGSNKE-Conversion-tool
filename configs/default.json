{
  "mastapp_base_url": "https://mastapp.site/json",
  "required_groups": [
    "pf_active",
    "magnetics",
    "wall"
  ],
  "optional_groups": [
    "pf_passive"
  ],
  "level2_s3_prefix": "s3://mast/level2/shots",
  "s5cmd_path": "s5cmd",
  "runs_dir": "SHOT",
  "cache_dir": "data_cache",
  "formed_plasma_frac": 0.8,
  "allow_missing_geometry": false,
  "execute_freegsnke": true,
  "freegsnke_run_mode": "both",
  "execute_evolutive": true,
  "freegsnke_python": ".venv-freegsnke/Scripts/python.exe",
  "diagnostics_compare": [],
  "diagnostic_contracts_path": "configs/diagnostic_contracts.json",
  "diagnostic_calibration_path": "configs/diagnostic_calibration.json",
  "passive_resistivity_path": "configs/passive_resistivity.json",
  "coil_map_path": "configs/coil_map.json",
  "voltage_map_path": "configs/voltage_map.json",
  "evolutive_authority_path": "configs/evolutive_authority.json",
  "enable_contract_metrics": true,
  "enable_experimental_data": true,
  "experimental_data_plots": true,
  "experimental_data_include_l1": true,
  "experimental_data_include_l3": true,
  "metrics_n_times": 5,
  "write_equilibrium_gifs": true,
  "write_eq_frames": true,
  "equilibrium_gif_fps": 2.0,
  "equilibrium_gif_dpi": 100,
  "freegsnke_script_timeout_s": 1200,
  "machine_authority_dir": "machine_authority",
  "require_machine_authority": true,
  "rebuild_machine_authority": true,
  "provenance_hash_data": false,
  "allow_cache_reuse": true,
  "batch_abort_on_failure": false,
  "enable_shot_suitability_gate": true,
  "s3_layout_patterns": [
    "{prefix}/{shot}.zarr/{group}",
    "{prefix}/{shot}.zarr/{group}/*",
    "{prefix}/shot_{shot}.zarr/{group}",
    "{prefix}/shot_{shot}.zarr/{group}/*"
  ],
  "s3_endpoint_url": "https://s3.echo.stfc.ac.uk",
  "s3_no_sign_request": true,
  "s5cmd_timeout_s": 60
}
