    "elongation",
    "elongation_axis",
    "triangularity_upper",
    "triangularity_lower",
    "minor_radius",
    "magnetic_axis_r",
    "magnetic_axis_z",
    "x_point_r",
    "x_point_z",
    "q95",
    "beta_tor",
    "beta_pol",
    "beta_normal",
    "li",
    "wmhd"
  ],
  "lcfs_vars": ["lcfs_r", "lcfs_z"],
  "psi_var": "psi",
  "time_policy": "nearest_to_window_midpoint",
  "notes": "ADR-002/v11.10. Shape scorecard metrics follow Pentland et al. arXiv:2407.12432 (axis, midplane R, X-point, LCFS distance). Mode is reconstruction_vs_archive, not EFIT++→FreeGSNKE forward replay."
}
