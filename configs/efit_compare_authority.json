{
  "authority_name": "efit_compare",
  "authority_version": "1.1",
  "source": "fairmast_level2_equilibrium",
  "label": "FAIR-MAST EFIT++ archive (not efit-ai Fortran)",
  "tokamark_reference": "https://github.com/UKAEA-IBM-STFC-Fusion-FMs/tokamark",
  "fairmast_docs": "https://mastapp.site/level2-data.html",
  "validation_reference": "https://arxiv.org/html/2407.12432v4",
  "compare_mode": "reconstruction_vs_archive",
  "psi_convention": "Wb_per_2pi",
  "equilibrium_group": "equilibrium",
